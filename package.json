{
  "name": "kenalin-monorepo",
  "version": "0.6.0",
  "private": true,
  "description": "Kenalin — open-source, embeddable AI introduction layer for portfolio and professional websites.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "eval": "jiti evals/runner.ts",
    "ingest": "pnpm --filter @kenalin/server run ingest",
    "check:owner-strings": "node scripts/check-owner-strings.mjs",
    "check:config-doc": "node scripts/check-config-doc.mjs",
    "verify": "pnpm run check:owner-strings && pnpm build && pnpm -r run typecheck && pnpm run check:config-doc && pnpm test",
    "release:dry": "pnpm build && pnpm -r publish --dry-run --no-git-checks",
    "release": "pnpm run verify && pnpm -r publish --access public"
  },
  "dependencies": {
    "@kenalin/core": "workspace:*"
  },
  "devDependencies": {
    "@kenalin/server": "workspace:*",
    "@types/node": "^22.10.0",
    "jiti": "^2.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
