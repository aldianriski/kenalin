# Kenalin — environment secrets (never commit the real .env)
# Only secrets live here; all behavior lives in kenalin.config.ts (PRD §D10).

# Google Gemini API key — powers both chat (gemini-2.5-flash) and
# embeddings (gemini-embedding-001). One key covers the whole MVP.
# The loader also accepts GEMINI_API_KEY, API_KEY_GEMINI, or API_KEY as fallbacks.
KENALIN_LLM_API_KEY=your-gemini-api-key-here

# Optional: HMAC secret for signing outbound webhook payloads
# (X-Kenalin-Signature header). Required only when handoff.webhook is configured.
KENALIN_WEBHOOK_SECRET=

# Optional: server port (default 8787)
PORT=8787
