# Copy to `.env` and fill in. Secrets never go in kenalin.config.ts.

# Google Gemini API key (chat + embeddings). Required for a real chat turn.
# Get one at https://aistudio.google.com/apikey
KENALIN_LLM_API_KEY=

# Optional — signs outgoing handoff webhooks (only if you configure handoff.webhook).
# KENALIN_WEBHOOK_SECRET=

# Optional — override the server port (default 8787).
# PORT=8787
