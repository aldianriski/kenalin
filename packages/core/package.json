{
  "name": "@kenalin/core",
  "version": "0.5.3",
  "description": "Kenalin core — pure TS schemas, config, orchestration, policies and interfaces. Zero I/O.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "homepage": "https://github.com/aldianriski/kenalin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aldianriski/kenalin.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/aldianriski/kenalin/issues",
  "keywords": [
    "kenalin",
    "ai",
    "assistant",
    "portfolio",
    "chatbot",
    "rag",
    "typescript",
    "zod"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
