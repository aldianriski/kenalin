{
  "name": "@kenalin/server",
  "version": "0.5.0",
  "description": "Kenalin server — Hono API, Gemini provider, local knowledge index, ingest CLI. The only package with I/O.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kenalin": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:embed": "tsup --config tsup.embed.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "ingest": "jiti src/cli.ts ingest",
    "dev": "jiti src/dev-server.ts",
    "eval": "jiti ../../evals/runner.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@kenalin/core": "workspace:*",
    "hono": "^4.6.14",
    "jiti": "^2.4.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
